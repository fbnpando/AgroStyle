rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Documentos subidos por el productor (solo dueño puede escribir, todos los autenticados leen)
    match /documents/{uid}/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // Imagenes de productos: solo el productor dueno puede escribir; cualquiera autenticado lee
    match /products/{uid}/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
